# Google Cloud / Gemini API configuration
# Use ONE of the following auth methods:

# Option A: Google AI Studio API Key (simplest for development)
GOOGLE_API_KEY=your-api-key-here

# Option B: Vertex AI (for production / Cloud Run)
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Agent model (must support Live API bidi-streaming)
DEMO_AGENT_MODEL=gemini-2.0-flash-live-001
